# Files kept in the repo but NOT uploaded/served to the Cloudflare edge.
# gitignore-style patterns, relative to the assets directory (repo root).

# Version control + full history (closes the .git exposure)
.git
.git/**

# Local tooling, config, and secrets — never served
.gitignore
.assetsignore
.claude
.claude/**
.dev.vars*
.env*
wrangler.jsonc
wrangler.toml

# OS cruft
.DS_Store
**/.DS_Store

# Dev docs + source-only generators (not browsed)
CLAUDE.md
og-image.html
